            "url": {
              "raw": "{{base_url}}/bookings/verification/me",
              "host": ["{{base_url}}"],
              "path": ["bookings", "verification", "me"]
            },
            "description": "Get customer's verification status"
          }
        },
        {
          "name": "2. Upload Verification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customer_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"licenseNumber\": \"ABC123456\",\n  \"expiryDate\": \"2027-12-31\",\n  \"licenseFrontPhoto\": \"file-id-front\",\n  \"licenseBackPhoto\": \"file-id-back\",\n  \"frontSelfie\": \"file-id-selfie-front\",\n  \"leftSelfie\": \"file-id-selfie-left\",\n  \"rightSelfie\": \"file-id-selfie-right\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/bookings/verification",
              "host": ["{{base_url}}"],
              "path": ["bookings", "verification"]
            }
          }
        },
        {
          "name": "3. Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"booking_id\", jsonData.booking.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customer_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vehicleId\": \"{{vehicle_id}}\",\n  \"startDate\": \"2026-03-01T10:00:00Z\",\n  \"endDate\": \"2026-03-05T10:00:00Z\",\n  \"pickupLocation\": {\n    \"displayName\": \"District 1, HCMC\",\n    \"latitude\": 10.7769,\n    \"longitude\": 106.7009\n  },\n  \"dropoffLocation\": {\n    \"displayName\": \"District 7, HCMC\",\n    \"latitude\": 10.7320,\n    \"longitude\": 106.7190\n  },\n  \"driverRequired\": false,\n  \"insuranceCoverage\": 30,\n  \"provider\": \"vnpay\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/bookings",
              "host": ["{{base_url}}"],
              "path": ["bookings"]
            }
          }
        },
