              "mode": "raw",
              "raw": "{\n  \"conditionPhotos\": [\"photo-id-1\", \"photo-id-2\", \"photo-id-3\"],\n  \"odometerReading\": 50000,\n  \"notes\": \"Car condition is excellent\"\n}",
